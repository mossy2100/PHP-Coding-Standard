<?xml version="1.0"?>
<ruleset name="OceanMoon PHP Coding Standard">
    <description>Coding standard for the OceanMoon packages by Shaun Moss.</description>

    <!-- Paths to check -->
    <file>src</file>

    <!-- Use OceanMoon PHP Coding Standard (includes PSR12 + additional rules) -->
    <rule ref="OceanMoon"/>

    <exclude-pattern>*/Tests/*.inc</exclude-pattern>
    <exclude-pattern>*/Tests/*.inc.fixed</exclude-pattern>
    <exclude-pattern>*/ScopeIndentSniff.php</exclude-pattern>

</ruleset>
