<?xml version="1.0"?>
<ruleset name="Ocean Moon PHP Coding Standard">
    <description>Coding standard for the Ocean Moon PHP packages.</description>

    <!-- Paths to check -->
    <file>src</file>

    <!-- OceanMoon Coding Standard (includes PSR12 + custom rules) -->
    <rule ref="OceanMoon"/>

    <exclude-pattern>*/Tests/*.inc</exclude-pattern>
    <exclude-pattern>*/Tests/*.inc.fixed</exclude-pattern>
    <exclude-pattern>*/ScopeIndentSniff.php</exclude-pattern>

</ruleset>
